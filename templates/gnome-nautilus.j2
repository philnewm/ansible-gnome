# This file is managed by Ansible

{% set nautilus_dconf_settings = gnome_nautilus_settings.get(gnome_major_version, gnome_nautilus_settings[gnome_settings_fallback]) %}
{% set sections_dict = {} %}
{% for key, value in nautilus_dconf_settings | dictsort %}
{% set section = key | dirname %}
{% set option = key | basename %}
{% if section not in sections_dict %}
{% set _ = sections_dict.update({section: {}}) %}
{% endif %}
{% set _ = sections_dict[section].update({option: value}) %}
{% endfor %}

{% for section, options in sections_dict | dictsort %}
[{{ section }}]
{% for option, value in options | dictsort %}
{{ option }}={{ value | string }}
{% endfor %}
{% if not loop.last %}

{% endif %}
{% endfor %}
